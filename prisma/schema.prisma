// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String           @id @default(cuid())
  name                String
  email               String           @unique
  emailVerified       Boolean          @default(false)
  image               String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  phoneNumber         String?          @unique
  phoneNumberVerified Boolean?         @default(false)
  role                String?          @default("user")
  banned              Boolean?         @default(false)
  banReason           String?
  banExpires          DateTime?
  accounts            Account[]
  sessions            Session[]
  surveySubmissions   SurveySubmission[]

  @@map("user")
}

model Session {
  id             String    @id @default(cuid())
  expiresAt      DateTime
  token          String    @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([providerId, accountId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum SurveyQuestionType {
  TEXT
  TEXTAREA
  NUMBER
  DROPDOWN
  RADIO
  CHECKBOX
  BOOLEAN
  DATE
  EMAIL
  SEARCH_SELECT
}

enum SurveyResponseMode {
  SINGLE_SELECT
  MULTI_SELECT
}

enum SurveyQuestionDataSource {
  COUNTRY
  CITY
  LANGUAGE
}

model SurveyQuestion {
  id              String                      @id @default(cuid())
  sortOrder       Int                         @default(0)
  required        Boolean                     @default(false)
  prompt          String
  type            SurveyQuestionType
  responseMode    SurveyResponseMode          @default(SINGLE_SELECT)
  datasource      SurveyQuestionDataSource?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  comboOptions    SurveyQuestionComboOption[]
  surveyAnswers   SurveyAnswer[]

  @@map("survey_questions")
}

model SurveyQuestionComboOption {
  id         String         @id @default(cuid())
  questionId String
  label      String
  sortOrder  Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("survey_question_combo_options")
}

model SurveySubmission {
  id            String         @id @default(cuid())
  userId        String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  surveyAnswers SurveyAnswer[]

  @@index([userId])
  @@map("survey_submissions")
}

model SurveyAnswer {
  id            String           @id @default(cuid())
  submissionId  String
  questionId    String
  textValue     String?
  numberValue   Float?
  booleanValue  Boolean?
  cityId        String?
  languageId    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  submission    SurveySubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question      SurveyQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  city          City?            @relation(fields: [cityId], references: [id], onDelete: Cascade)
  language      Language?        @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([questionId])
  @@index([cityId])
  @@index([languageId])
  @@map("survey_answers")
}

model Country {
  id          String   @id @default(cuid())

  name        String
  isoCode     String   @unique   // US, ZW, GB
  phoneCode   String?            // +1, +263
  currency    String?            // USD, ZWL
  emoji       String?            // 🇿🇼

  cities      City[]

  createdAt   DateTime @default(now())

  @@index([name])
  @@map("country")
}

model City {
  id              String   @id @default(cuid())

  name            String
  countryId       String
  country         Country  @relation(fields: [countryId], references: [id])

  stateCode       String?

  latitude        Float?
  longitude       Float?

  population      Int?

  surveyAnswers   SurveyAnswer[]

  createdAt       DateTime @default(now())

  @@index([name])
  @@index([countryId])
  @@map("city")
}

model Language {
  id              String           @id @default(cuid())

  name            String
  localName       String?
  iso6391         String           @unique

  surveyAnswers   SurveyAnswer[]

  createdAt       DateTime         @default(now())

  @@index([name])
  @@index([localName])
  @@map("language")
}
